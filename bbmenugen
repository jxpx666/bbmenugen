# $generated_menu .= prepare_item("firefox", "Firefox");
# $generated_menu .= "[end]\n";


###############################################################################
# Output final com confirmação de overwrite
###############################################################################
if ($create_menu) {

    # Segurança: exigir destino explícito
    if (!$pipe && !defined $menu_file) {
        die "[!] You must specify -p (STDOUT) or -o <file> when using -g\n";
    }

    # Confirmação de overwrite
    if (-f $menu_file && !$pipe) {
        print "[!] File '$menu_file' already exists. Overwrite? (y/N): ";
        chomp(my $answer = <STDIN>);
        unless ($answer =~ /^[Yy]$/) {
            print "[*] Aborted. Menu not written.\n";
            exit;
        }
    }

    if ($pipe) {
        print $generated_menu;
    }
    else {
        open my $fh, '>', $menu_file
          or die "Cannot write $menu_file: $!";
        print $fh $generated_menu;
        close $fh;

        print STDERR ":: Menu written to $menu_file (mode '$mode')\n";
    }
}
else {
    print STDERR "[!] Use -g to generate the menu\n";

}
###############################################################################
# Fim do script
